<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="AccessGuardian">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <div class="flex">
      <nav class="w-56 bg-white border-r border-gray-200 min-h-screen p-4 hidden lg:block">
        <div class="text-lg font-bold text-gray-900 mb-6">AccessGuardian</div>
        <div class="space-y-1">
          <a href="/" class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-gray-100">
            Dashboard
          </a>
          <a
            href="/requests"
            class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-gray-100"
          >
            Access Requests
          </a>
          <a
            href="/applications"
            class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-gray-100"
          >
            Applications
          </a>
        </div>
      </nav>
      <main class="flex-1">
        {@inner_content}
      </main>
    </div>
  </body>
</html>
