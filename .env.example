# Slack
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_ENABLED=true

# GitHub (real API integration)
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_ORG=your-org-name

# GitLab (agentic integration via Playwright)
# Session is captured via the setup page at /integrations/setup
GITLAB_GROUP_PATH=access-guardian-demo

# Playwright service (default for Docker)
PLAYWRIGHT_SERVICE_URL=http://playwright:3000
